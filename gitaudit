#!/usr/bin/env bash
# gitaudit - Git repository secrets and hygiene scanner
#
# Scans for accidentally committed secrets, large files, and .gitignore gaps.
# Checks both the working tree AND full git history.
#
# Usage:
#   curl -fsSL https://subhajit-paul.github.io/gitaudit | bash
#   curl -fsSL https://subhajit-paul.github.io/gitaudit | bash -s -- /path/to/repo
#   curl -fsSL https://subhajit-paul.github.io/gitaudit | bash -s -- --no-history  # skip git log scan (faster)

set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

info()    { echo -e "${BLUE}[·]${NC} $*"; }
success() { echo -e "${GREEN}[✓]${NC} $*"; }
warn()    { echo -e "${YELLOW}[!]${NC} $*"; }
critical(){ echo -e "${RED}${BOLD}[!]${NC} $*"; }
header()  { echo -e "\n${BOLD}${CYAN}━━━  $*  ━━━${NC}"; }

TOTAL_FINDINGS=0
CRITICAL_FINDINGS=0
WARN_FINDINGS=0

finding_critical() {
  critical "CRITICAL: $*"
  TOTAL_FINDINGS=$((TOTAL_FINDINGS + 1))
  CRITICAL_FINDINGS=$((CRITICAL_FINDINGS + 1))
}

finding_warn() {
  warn "WARNING:  $*"
  TOTAL_FINDINGS=$((TOTAL_FINDINGS + 1))
  WARN_FINDINGS=$((WARN_FINDINGS + 1))
}

# ── Arguments ─────────────────────────────────────────────────────────────────

REPO_PATH="${1:-$(pwd)}"
SKIP_HISTORY=false

for arg in "$@"; do
  case "$arg" in
    --no-history) SKIP_HISTORY=true ;;
    -*) ;;
    *) REPO_PATH="$arg" ;;
  esac
done

REPO_PATH=$(realpath "$REPO_PATH" 2>/dev/null || echo "$REPO_PATH")

# ── Validate repo ─────────────────────────────────────────────────────────────

echo ""
echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════════╗${NC}"
printf  "${BOLD}${CYAN}║${NC}  %-44s${BOLD}${CYAN}║${NC}\n" "gitaudit — $(date '+%Y-%m-%d %H:%M:%S')"
echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════╝${NC}"

[ -d "$REPO_PATH" ] || { echo -e "${RED}[✗]${NC} Directory not found: $REPO_PATH"; exit 1; }
cd "$REPO_PATH"

IS_GIT=false
git rev-parse --is-inside-work-tree >/dev/null 2>&1 && IS_GIT=true

info "Scanning: ${BOLD}${REPO_PATH}${NC}"
$IS_GIT && info "Git repo: $(git log --oneline 2>/dev/null | wc -l | tr -d ' ') commits, \
$(git branch -a 2>/dev/null | wc -l | tr -d ' ') branches"

# ── Secret patterns ───────────────────────────────────────────────────────────
# Each entry: "LABEL|SEVERITY|GREP_PATTERN"
# Patterns avoid matching common test/example placeholder strings

PATTERNS=(
  "AWS Access Key ID|critical|AKIA[0-9A-Z]{16}"
  "AWS Secret Access Key|critical|aws_secret_access_key\s*[=:]\s*['\"][0-9A-Za-z/+=]{40}['\"]"
  "GitHub Personal Access Token|critical|gh[pousr]_[A-Za-z0-9]{36,255}"
  "GitHub Fine-grained PAT|critical|github_pat_[A-Za-z0-9_]{22,255}"
  "Stripe Live Secret Key|critical|sk_live_[0-9a-zA-Z]{24}"
  "Stripe Test Key (committed)|warn|sk_test_[0-9a-zA-Z]{24}"
  "Slack Bot Token|critical|xox[baprs]-[0-9]{10,12}-[0-9]{10,12}-[0-9A-Za-z]{24}"
  "Slack Webhook URL|warn|hooks\.slack\.com/services/T[0-9A-Z]+/B[0-9A-Z]+/[0-9A-Za-z]+"
  "Private Key (PEM)|critical|-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----"
  "Database URL with credentials|critical|(postgres|postgresql|mysql|mongodb|redis)://[^:@\s]+:[^@\s]+@[^\s'\"]+"
  "Generic password assignment|warn|(password|passwd|pwd|secret)\s*[=:]\s*['\"][^'\"]{8,}['\"]"
  "Generic API key assignment|warn|(api_key|apikey|api-key|access_key|auth_token)\s*[=:]\s*['\"][^'\"]{16,}['\"]"
  "Bearer token in code|warn|Bearer\s+[A-Za-z0-9_.\-]{20,}"
  "HuggingFace token|critical|hf_[A-Za-z0-9]{34}"
  "OpenAI API key|critical|sk-[A-Za-z0-9]{48}"
  "Anthropic API key|critical|sk-ant-[A-Za-z0-9_\-]{93}"
  "Google API key|warn|AIza[0-9A-Za-z_\-]{35}"
  "Twilio credentials|warn|AC[0-9a-fA-F]{32}"
  "SendGrid API key|critical|SG\.[A-Za-z0-9_\-]{22}\.[A-Za-z0-9_\-]{43}"
)

# Files/paths to exclude from scanning (test fixtures, docs, examples, etc.)
EXCLUDE_PATHS=(
  "*.lock" "*.sum" "go.sum" "package-lock.json" "yarn.lock" "Cargo.lock"
  "node_modules/*" ".git/*" "*.min.js" "vendor/*"
  "test*" "*_test.*" "*spec*" "*fixture*" "*example*" "*sample*" "*mock*"
  "CHANGELOG*" "*.md" "docs/*"
)

build_exclude_args() {
  local args=""
  for p in "${EXCLUDE_PATHS[@]}"; do
    args="$args --exclude=$p --exclude-dir=$(dirname "$p" 2>/dev/null || echo '.')"
  done
  echo "$args"
}

# ── Scan working tree ─────────────────────────────────────────────────────────

header "Scanning Working Tree"

TRACKED_FILES=()
if $IS_GIT; then
  while IFS= read -r f; do
    TRACKED_FILES+=("$f")
  done < <(git ls-files 2>/dev/null)
fi

scan_content() {
  local content="$1" source_label="$2"
  for pattern_entry in "${PATTERNS[@]}"; do
    local label sev pattern
    IFS='|' read -r label sev pattern <<< "$pattern_entry"
    local matches
    matches=$(echo "$content" | grep -onP "$pattern" 2>/dev/null || true)
    if [ -n "$matches" ]; then
      while IFS= read -r match; do
        local line_num="${match%%:*}"
        local matched_text="${match#*:}"
        # Redact: show first 6 chars + *** + last 4 chars of sensitive value
        local display
        display=$(echo "$matched_text" | sed 's/\(.\{6\}\).\{4,\}\(.\{4\}\)/\1***\2/g')
        if [ "$sev" = "critical" ]; then
          finding_critical "${label} in ${source_label}:${line_num}  →  ${display}"
        else
          finding_warn     "${label} in ${source_label}:${line_num}  →  ${display}"
        fi
      done <<< "$matches"
    fi
  done
}

if [ "${#TRACKED_FILES[@]}" -gt 0 ]; then
  for f in "${TRACKED_FILES[@]}"; do
    [[ -f "$f" ]] || continue
    # Skip binaries and very large files
    file_size=$(wc -c < "$f" 2>/dev/null || echo 0)
    [ "$file_size" -gt $((2*1024*1024)) ] && continue
    file "$f" 2>/dev/null | grep -qiE 'binary|image|audio|video|compiled' && continue

    content=$(cat "$f" 2>/dev/null || true)
    [ -n "$content" ] && scan_content "$content" "$f"
  done
else
  # Not a git repo — scan all files
  while IFS= read -r f; do
    file_size=$(wc -c < "$f" 2>/dev/null || echo 0)
    [ "$file_size" -gt $((2*1024*1024)) ] && continue
    file "$f" 2>/dev/null | grep -qiE 'binary|image|audio|video' && continue
    content=$(cat "$f" 2>/dev/null || true)
    [ -n "$content" ] && scan_content "$content" "$f"
  done < <(find . -type f -not -path './.git/*' -not -path './node_modules/*' 2>/dev/null)
fi

[ "$TOTAL_FINDINGS" -eq 0 ] && success "No secrets found in working tree"

# ── Scan git history ──────────────────────────────────────────────────────────

if $IS_GIT && ! $SKIP_HISTORY; then
  FINDINGS_BEFORE=$TOTAL_FINDINGS
  header "Scanning Git History"
  info "Scanning all commits for secrets... (use --no-history to skip)"

  COMMIT_COUNT=$(git rev-list --all --count 2>/dev/null || echo 0)
  info "${COMMIT_COUNT} commits to scan"

  git log --all --diff-filter=A --name-only --pretty=format: 2>/dev/null | \
  grep -v '^$' | sort -u | \
  while IFS= read -r f; do
    content=$(git show "HEAD:$f" 2>/dev/null || true)
    [ -z "$content" ] && continue
    scan_content "$content" "history:${f}"
  done

  # Also scan patches for removed secrets
  git log --all -p --diff-filter=D 2>/dev/null | grep '^-' | \
  while IFS= read -r line; do
    scan_content "$line" "deleted-content"
  done

  NEW_FINDINGS=$((TOTAL_FINDINGS - FINDINGS_BEFORE))
  [ "$NEW_FINDINGS" -eq 0 ] && success "No additional secrets found in git history"
  [ "$NEW_FINDINGS" -gt 0 ] && \
    warn "${NEW_FINDINGS} additional issue(s) found in history — consider git filter-repo to purge"
fi

# ── Large file check ──────────────────────────────────────────────────────────

if $IS_GIT; then
  header "Large Files in Repository"

  LARGE_FILES=$(git rev-list --objects --all 2>/dev/null \
    | git cat-file --batch-check='%(objecttype) %(objectname) %(objectsize) %(rest)' 2>/dev/null \
    | awk '$1=="blob" && $3>1048576 {printf "  %.1f MiB  %s\n", $3/1048576, $4}' \
    | sort -rn | head -10)

  if [ -n "$LARGE_FILES" ]; then
    finding_warn "Large files tracked in git history:"
    echo -e "${YELLOW}$LARGE_FILES${NC}"
    echo -e "  ${DIM}Consider git filter-repo or git lfs for these${NC}"
  else
    success "No files over 1 MiB tracked in git history"
  fi
fi

# ── Unencrypted key files ─────────────────────────────────────────────────────

header "Key Files"

KEY_FILES=$(find . -not -path './.git/*' -not -path './node_modules/*' \
  \( -name "*.pem" -o -name "*.key" -o -name "id_rsa" -o -name "id_ed25519" \
     -o -name "id_ecdsa" -o -name "*.p12" -o -name "*.pfx" \) 2>/dev/null)

if [ -n "$KEY_FILES" ]; then
  while IFS= read -r kf; do
    if grep -ql "PRIVATE KEY" "$kf" 2>/dev/null; then
      finding_critical "Unencrypted private key file: ${kf}"
    else
      finding_warn "Key/cert file present: ${kf}"
    fi
  done <<< "$KEY_FILES"
else
  success "No key files found"
fi

# ── .gitignore coverage check ─────────────────────────────────────────────────

header ".gitignore Coverage"

GITIGNORE_CHECKS=(
  ".env|.env file"
  "*.pem|PEM files"
  "*.key|key files"
  "__pycache__/|Python cache"
  "node_modules/|node_modules"
  ".venv/|Python venv"
  "*.log|log files"
  "secrets.json|secrets.json"
  ".DS_Store|macOS metadata"
)

if [ -f ".gitignore" ]; then
  for entry in "${GITIGNORE_CHECKS[@]}"; do
    pattern="${entry%%|*}"
    label="${entry##*|}"
    if ! grep -q "$pattern" .gitignore 2>/dev/null; then
      finding_warn ".gitignore missing: ${label} (${pattern})"
    fi
  done
  [ "$WARN_FINDINGS" -eq 0 ] && [ "$CRITICAL_FINDINGS" -eq 0 ] && \
    success ".gitignore looks comprehensive"
else
  finding_warn "No .gitignore found"
fi

# ── .env files check ──────────────────────────────────────────────────────────

header ".env Files"

ENV_FILES=$(find . -not -path './.git/*' -name '.env' -o -name '.env.local' \
  -o -name '.env.production' -o -name '.env.staging' 2>/dev/null | grep -v '.example')

if [ -n "$ENV_FILES" ]; then
  while IFS= read -r ef; do
    if $IS_GIT && git ls-files --error-unmatch "$ef" >/dev/null 2>&1; then
      finding_critical "${ef} is tracked by git (should be in .gitignore)"
    else
      warn "${ef} exists locally (not tracked — OK, but verify .gitignore)"
    fi
  done <<< "$ENV_FILES"
else
  success "No unintended .env files found"
fi

# ── Summary ───────────────────────────────────────────────────────────────────

echo ""
echo -e "${BOLD}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
if [ "$CRITICAL_FINDINGS" -gt 0 ]; then
  echo -e "${BOLD}${RED}  ✗  ${CRITICAL_FINDINGS} critical  ${WARN_FINDINGS} warnings  — action required${NC}"
elif [ "$WARN_FINDINGS" -gt 0 ]; then
  echo -e "${BOLD}${YELLOW}  !  ${WARN_FINDINGS} warnings  — review recommended${NC}"
else
  echo -e "${BOLD}${GREEN}  ✓  Clean — no issues found${NC}"
fi
echo -e "${BOLD}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

if [ "$CRITICAL_FINDINGS" -gt 0 ]; then
  echo ""
  echo -e "  ${BOLD}Remediation${NC}"
  echo -e "   1. Rotate any exposed credentials immediately"
  echo -e "   2. Remove secrets from history: ${BOLD}pip install git-filter-repo${NC}"
  echo -e "      ${BOLD}git filter-repo --path-glob '*.env' --invert-paths${NC}"
  echo -e "   3. Add patterns to .gitignore and force-push"
  echo -e "   4. Consider using a secrets manager (1Password, Vault, AWS Secrets Manager)"
fi

echo ""
exit $( [ "$CRITICAL_FINDINGS" -gt 0 ] && echo 1 || echo 0 )
