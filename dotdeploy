#!/usr/bin/env bash
# dotdeploy - Deploy dotfiles from any git repo to the current machine
#
# Clones a dotfiles repo and symlinks configs using GNU Stow (or falls back
# to manual symlinking). Existing files are backed up, not overwritten.
#
# Usage:
#   curl -fsSL https://subhajit-paul.github.io/dotdeploy | bash -s -- Subhajit-Paul
#   curl -fsSL https://subhajit-paul.github.io/dotdeploy | bash -s -- user/dotfiles
#   curl -fsSL https://subhajit-paul.github.io/dotdeploy | bash -s -- https://github.com/user/dotfiles
#   curl -fsSL https://subhajit-paul.github.io/dotdeploy | bash -s -- Subhajit-Paul --dir ~/.config/dotfiles
#   curl -fsSL https://subhajit-paul.github.io/dotdeploy | bash -s -- Subhajit-Paul --dry-run

set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

info()    { echo -e "${BLUE}[·]${NC} $*"; }
success() { echo -e "${GREEN}[✓]${NC} $*"; }
warn()    { echo -e "${YELLOW}[!]${NC} $*"; }
error()   { echo -e "${RED}[✗]${NC} $*" >&2; exit 1; }
header()  { echo -e "\n${BOLD}${CYAN}━━━  $*  ━━━${NC}"; }
dry()     { echo -e "${DIM}[dry-run]${NC} $*"; }

# ── Arguments ─────────────────────────────────────────────────────────────────

TARGET_ARG="${1:-}"
DOTFILES_DIR="$HOME/dotfiles"
DRY_RUN=false
PACKAGES=()

shift || true
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dir)      DOTFILES_DIR="$2"; shift 2 ;;
    --pkg)      PACKAGES+=("$2"); shift 2 ;;
    --dry-run)  DRY_RUN=true; shift ;;
    *)          shift ;;
  esac
done

[ -z "$TARGET_ARG" ] && {
  if [ -e /dev/tty ]; then
    printf "${BOLD}  GitHub username, user/repo, or URL: ${NC}"
    read -r TARGET_ARG < /dev/tty
  fi
}
[ -z "$TARGET_ARG" ] && error "Usage: bash -s -- <username|user/repo|URL> [--dir DIR] [--dry-run]"

# ── Resolve clone URL ─────────────────────────────────────────────────────────

header "Resolving Repository"

if echo "$TARGET_ARG" | grep -qE '^https?://'; then
  CLONE_URL="$TARGET_ARG"
elif echo "$TARGET_ARG" | grep -q '/'; then
  CLONE_URL="https://github.com/${TARGET_ARG}.git"
else
  CLONE_URL="https://github.com/${TARGET_ARG}/dotfiles.git"
fi

info "Source: ${CLONE_URL}"
info "Target: ${DOTFILES_DIR}"
$DRY_RUN && warn "Dry-run mode — no files will be written"

# ── Clone ─────────────────────────────────────────────────────────────────────

header "Cloning Dotfiles"

command -v git >/dev/null 2>&1 || error "git not found. Install git first."

if [ -d "$DOTFILES_DIR/.git" ]; then
  info "Repo already exists — pulling latest..."
  if $DRY_RUN; then
    dry "git -C $DOTFILES_DIR pull --ff-only"
  else
    git -C "$DOTFILES_DIR" pull --ff-only 2>/dev/null \
      && success "Pulled latest changes" \
      || warn "Could not pull — continuing with existing clone"
  fi
else
  if [ -d "$DOTFILES_DIR" ] && [ -n "$(ls -A "$DOTFILES_DIR" 2>/dev/null)" ]; then
    error "$DOTFILES_DIR exists and is not empty. Use --dir to specify a different path."
  fi
  if $DRY_RUN; then
    dry "git clone $CLONE_URL $DOTFILES_DIR"
  else
    git clone --depth=1 "$CLONE_URL" "$DOTFILES_DIR" 2>/dev/null \
      || error "Clone failed. Check the URL and your network connection."
    success "Cloned to ${DOTFILES_DIR}"
  fi
fi

# ── Detect stow packages ──────────────────────────────────────────────────────

header "Detecting Packages"

# If no packages specified, detect automatically
if [ "${#PACKAGES[@]}" -eq 0 ]; then
  # A "package" is any top-level directory in the dotfiles repo
  # that contains at least one file (not .git, not README, not scripts/)
  while IFS= read -r d; do
    pkg=$(basename "$d")
    # Skip known non-package dirs
    case "$pkg" in
      .git|scripts|bin|docs|README*|LICENSE*|install*|setup*) continue ;;
    esac
    [ -d "$d" ] && PACKAGES+=("$pkg")
  done < <(find "$DOTFILES_DIR" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | sort)
fi

if [ "${#PACKAGES[@]}" -eq 0 ]; then
  error "No stow packages detected in ${DOTFILES_DIR}. Ensure subdirs contain dotfiles."
fi

info "Packages found: ${PACKAGES[*]}"

# ── Deploy ────────────────────────────────────────────────────────────────────

header "Deploying"

BACKUP_DIR="$HOME/.dotfiles-backup-$(date +%s)"
LINKED=0
BACKED_UP=0
SKIPPED=0

if command -v stow >/dev/null 2>&1; then
  info "Using GNU Stow"

  for pkg in "${PACKAGES[@]}"; do
    PKG_DIR="${DOTFILES_DIR}/${pkg}"
    [ -d "$PKG_DIR" ] || { warn "Package dir not found: ${PKG_DIR}"; continue; }

    # Check for conflicts
    CONFLICTS=()
    while IFS= read -r src_file; do
      rel="${src_file#$PKG_DIR/}"
      dst="$HOME/$rel"
      if [ -e "$dst" ] && [ ! -L "$dst" ]; then
        CONFLICTS+=("$dst")
      fi
    done < <(find "$PKG_DIR" -type f 2>/dev/null)

    if [ "${#CONFLICTS[@]}" -gt 0 ]; then
      mkdir -p "$BACKUP_DIR/$pkg"
      for conflict in "${CONFLICTS[@]}"; do
        rel="${conflict#$HOME/}"
        if $DRY_RUN; then
          dry "backup $conflict → $BACKUP_DIR/$pkg/$rel"
        else
          mkdir -p "$BACKUP_DIR/$pkg/$(dirname "$rel")"
          mv "$conflict" "$BACKUP_DIR/$pkg/$rel"
          BACKED_UP=$((BACKED_UP + 1))
        fi
      done
      warn "Backed up ${#CONFLICTS[@]} conflicting file(s) from '${pkg}' to ${BACKUP_DIR}/"
    fi

    if $DRY_RUN; then
      dry "stow -d $DOTFILES_DIR -t $HOME $pkg"
      LINKED=$((LINKED + 1))
    else
      if stow -d "$DOTFILES_DIR" -t "$HOME" "$pkg" 2>/dev/null; then
        success "Linked: ${pkg}"
        LINKED=$((LINKED + 1))
      else
        warn "stow failed for '${pkg}' — trying manual linking"
        # Fall through to manual link
        SKIPPED=$((SKIPPED + 1))
      fi
    fi
  done

else
  warn "GNU Stow not found — symlinking manually"
  info "Install stow for cleaner management: apt install stow / pacman -S stow / dnf install stow"

  for pkg in "${PACKAGES[@]}"; do
    PKG_DIR="${DOTFILES_DIR}/${pkg}"
    [ -d "$PKG_DIR" ] || continue

    while IFS= read -r src_file; do
      rel="${src_file#$PKG_DIR/}"
      dst="$HOME/$rel"
      dst_dir="$(dirname "$dst")"

      if [ -e "$dst" ] && [ ! -L "$dst" ]; then
        mkdir -p "$BACKUP_DIR/$pkg/$(dirname "$rel")"
        if $DRY_RUN; then
          dry "backup $dst → $BACKUP_DIR/$pkg/$rel"
        else
          mv "$dst" "$BACKUP_DIR/$pkg/$rel"
          BACKED_UP=$((BACKED_UP + 1))
        fi
      fi

      if [ -L "$dst" ]; then
        SKIPPED=$((SKIPPED + 1))
        continue
      fi

      if $DRY_RUN; then
        dry "ln -sf $src_file → $dst"
      else
        mkdir -p "$dst_dir"
        ln -sf "$src_file" "$dst"
        LINKED=$((LINKED + 1))
      fi
    done < <(find "$PKG_DIR" -type f 2>/dev/null)
    success "Linked: ${pkg}"
  done
fi

# ── Post-deploy ────────────────────────────────────────────────────────────────

# Reload shell configs if they were linked
if [ -f "$HOME/.zshrc" ] && [ -n "${ZSH_VERSION:-}" ]; then
  info "Zsh config updated — run: source ~/.zshrc"
fi
if [ -f "$HOME/.bashrc" ] && [ -n "${BASH_VERSION:-}" ]; then
  info "Bash config updated — run: source ~/.bashrc"
fi

# ── Summary ───────────────────────────────────────────────────────────────────

echo ""
echo -e "${BOLD}${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
if $DRY_RUN; then
  echo -e "${BOLD}${YELLOW}  Dry-run complete — no files changed${NC}"
else
  echo -e "${BOLD}${GREEN}  ✓  Dotfiles deployed${NC}"
fi
echo -e "${BOLD}${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
printf "   %-20s %d package(s)\n"   "Deployed"  "${#PACKAGES[@]}"
printf "   %-20s %d file(s)\n"      "Linked"     "$LINKED"
[ "$BACKED_UP" -gt 0 ] && printf "   %-20s %d file(s) → %s\n" "Backed up" "$BACKED_UP" "$BACKUP_DIR"
[ "$SKIPPED"   -gt 0 ] && printf "   %-20s %d (already linked)\n" "Skipped"   "$SKIPPED"
echo ""
echo -e "  ${CYAN}Manage${NC}"
echo -e "   Update:   ${BOLD}git -C ~/dotfiles pull${NC}"
echo -e "   Remove:   ${BOLD}stow -d ~/dotfiles -t ~ -D <package>${NC}"
echo ""
